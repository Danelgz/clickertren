rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leaderboards: lectura pública, escritura abierta
    // (el juego controla quién escribe usando el UID como doc ID)
    match /leaderboard_train/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    match /leaderboard_wordle/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    // Partidas guardadas: lectura y escritura abierta
    // (cada usuario solo lee/escribe su propio UID como doc ID)
    match /saves_train/{docId} {
      allow read, write: if true;
    }

    match /saves_wordle/{docId} {
      allow read, write: if true;
    }

    // Nombres de usuario: solo el usuario autenticado puede leer/escribir su propio documento
    match /usernames/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }

    // Configuración de usuario: solo el usuario autenticado puede leer/escribir su propio documento
    match /userSettings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }

    // Salas de Wordle 1v1: lectura y escritura para usuarios autenticados
    match /wordle1v1_rooms/{roomCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
